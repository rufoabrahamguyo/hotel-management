# Copy to `.env` in repo root (optional) - Docker Compose reads these variables
# Example: `cp docker.env.example .env` then edit secrets before `docker compose up --build`

POSTGRES_USER=hotel
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_DB=hotel
# POSTGRES_PORT=5433
# BACKEND_PORT=4000

# REQUIRED — Compose will not start the API without these.
# Use a long random string (32+ chars). Never commit real secrets.
JWT_SECRET=replace-with-a-long-random-secret
# JWT_EXPIRES_IN=8h

# REQUIRED — initial SystemAdmin when the staff table has no admin yet.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-bootstrap-password
BOOTSTRAP_ADMIN_NAME=Administrator
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com

CORS_ORIGIN=http://localhost:5173

# Public org self-signup (creates SystemAdmin + first property). Off by default in Docker/production.
# ALLOW_PUBLIC_REGISTER=true
ALLOW_PUBLIC_REGISTER=false

# NODE_ENV=production

  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "NODE_ENV=test mocha --require @babel/register --require ./src/test/setup.js 'src/**/__tests__/**/*.test.js' 'src/**/__tests__/**/*.test.jsx'",
    "test:watch": "NODE_ENV=test mocha --require @babel/register --require ./src/test/setup.js --watch 'src/**/__tests__/**/*.test.js' 'src/**/__tests__/**/*.test.jsx'",
    "test:coverage": "nyc --reporter=text --reporter=html npm test",
    "test:verbose": "NODE_ENV=test mocha --require @babel/register --require ./src/test/setup.js --reporter spec 'src/**/__tests__/**/*.test.js' 'src/**/__tests__/**/*.test.jsx'"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",

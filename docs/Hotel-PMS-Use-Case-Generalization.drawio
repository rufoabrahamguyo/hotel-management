        <!-- Notes / legend -->
        <mxCell id="legend" value="&lt;b&gt;Legend (course style)&lt;/b&gt;&lt;br&gt;&lt;br&gt;▷ Solid arrow with hollow triangle = &lt;b&gt;generalization&lt;/b&gt; (child actor inherits parent&amp;#39;s use cases)&lt;br&gt;Example: General Manager inherits Receptionist → … → Hotel Staff use cases&lt;br&gt;&lt;br&gt;- - → &amp;lt;&amp;lt;include&amp;gt;&amp;gt; = mandatory sub-step (JWT/session check on protected actions)&lt;br&gt;&lt;br&gt;▷ Between use cases = specialized behavior (e.g. Suspend Staff specializes Manage Staff Account)&lt;br&gt;&lt;br&gt;&lt;b&gt;App roles on diagram:&lt;/b&gt; SystemAdmin, GeneralManager, FrontOfficeManager, Receptionist, Housekeeping(Manager), Maintenance(Manager), RevenueManager, Accountant — no separate mapping table needed." style="text;html=1;strokeColor=#999999;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=10;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="790" width="560" height="200" as="geometry" />
        </mxCell>

        <mxCell id="inherit-note" value="&lt;b&gt;Inheritance chains&lt;/b&gt;&lt;br&gt;Management: System Admin → General Manager → Front Office Manager → Receptionist → Hotel Staff&lt;br&gt;Housekeeping: HK Manager → Housekeeping → Hotel Staff&lt;br&gt;Maintenance: Maint Manager → Maintenance → Hotel Staff&lt;br&gt;Finance: Revenue Manager / Accountant → Hotel Staff" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="790" width="540" height="100" as="geometry" />
        </mxCell>


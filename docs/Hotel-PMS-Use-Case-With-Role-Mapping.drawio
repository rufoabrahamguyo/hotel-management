        <!-- Application role → diagram actor mapping -->
        <mxCell id="role-mapping" value="&lt;b&gt;Application role → Diagram actor mapping&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table cellpadding=&quot;4&quot; style=&quot;width:100%;font-size:10px;border-collapse:collapse;&quot;&gt;&lt;tr style=&quot;background-color:#e8e8e8;&quot;&gt;&lt;td&gt;&lt;b&gt;Application role (in system)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Diagram actor&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;SystemAdmin&lt;/td&gt;&lt;td&gt;System Admin&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;GeneralManager&lt;/td&gt;&lt;td&gt;General Manager&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;FrontOfficeManager&lt;/td&gt;&lt;td&gt;General Manager / Receptionist&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Receptionist&lt;/td&gt;&lt;td&gt;Receptionist&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;HousekeepingManager&lt;/td&gt;&lt;td&gt;Housekeeping Staff&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Housekeeping&lt;/td&gt;&lt;td&gt;Housekeeping Staff&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;MaintenanceManager&lt;/td&gt;&lt;td&gt;Maintenance Staff&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Maintenance&lt;/td&gt;&lt;td&gt;Maintenance Staff&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;RevenueManager&lt;/td&gt;&lt;td&gt;Revenue Manager&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Accountant&lt;/td&gt;&lt;td&gt;Revenue Manager&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#666;&quot;&gt;Managers not drawn separately inherit their team&amp;#39;s use cases; FOM may also perform GM/Receptionist duties.&lt;/font&gt;" style="text;html=1;strokeColor=#333333;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;whiteSpace=wrap;overflow=hidden;rounded=1;fontSize=11;" vertex="1" parent="1">

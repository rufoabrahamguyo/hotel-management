# PostgreSQL - local Node (outside Docker)
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/hotel
#
# When API runs in Docker Compose, DATABASE_URL is set for you. For local backend + Docker Postgres only:
# DATABASE_URL=postgresql://hotel:hotel@localhost:5432/hotel

# System / IT bootstrap (role SystemAdmin, once when no system admin exists in staff). Use a strong password.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password
BOOTSTRAP_ADMIN_NAME=System Administrator
# Optional - also used for login if set:
# BOOTSTRAP_ADMIN_EMAIL=admin@yourhotel.com

# Required for JWT sign-in and staff API (must be the same for sign/verify).
# Production refuses to start if this is missing, short, or a documented placeholder.
JWT_SECRET=change-me-to-a-long-random-string
# JWT_EXPIRES_IN=8h

# Optional: comma-separated allowed origins for CORS (default: allow all in dev)
# CORS_ORIGIN=http://localhost:5173

# Public self-serve org registration (POST /api/auth/register).
# Unset: allowed when NODE_ENV is not production; denied in production.
# ALLOW_PUBLIC_REGISTER=true
# ALLOW_PUBLIC_REGISTER=false

PORT=4000
# NODE_ENV=development
